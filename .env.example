# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# REQUIRED in production — must match your actual domain exactly
NEXTAUTH_URL=https://optim-soln.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-char-secret

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must also be set for client-side Google buttons
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...

# ─── Email (Hostinger SMTP) ────────────────────────────────────────────────────
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=training@agile-edge.com
EMAIL_PASS=your-email-password

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=your-admin-password

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://optim-soln.com
